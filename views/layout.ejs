<!-- @format -->

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Reflections' %></title>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400..900&display=swap" rel="stylesheet" />
		<link rel="stylesheet" href="/styles.css" />
		<link rel="stylesheet" href="/stage-overrides.css" />
		<link
			rel="stylesheet"
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
			integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
			crossorigin="anonymous"
			referrerpolicy="no-referrer" />
	</head>
	<body
		data-logged-in="<%= user ? 'true' : 'false' %>"
		data-user-logged-in="<%= user ? 'true' : '' %>"
		data-has-sculpture="<%= typeof hasSculpture !== 'undefined' ? hasSculpture : false %>"
		data-stage="<%= typeof stage !== 'undefined' ? stage : '1' %>"
		data-current-page="<%= typeof currentPage !== 'undefined' ? currentPage : '' %>"
	>
		<%- include('partials/filters') %>
		<video
			id="background-video"
			autoplay
			loop
			muted
			playsinline
			style="position: fixed; right: 0; bottom: 0; min-width: 100vw; min-height: 100vh; z-index: -1; object-fit: cover">
			<source src="/smokeBackground.mp4" type="video/mp4" />
			Your browser does not support the video tag.
		</video>

		<% if (typeof stage === 'undefined' || stage !== '2') { %>
			<%- include('partials/header', { user, currentPage, stage: typeof stage !== 'undefined' ? stage : '1', hasSculpture: typeof hasSculpture !== 'undefined' ? hasSculpture : false }) %>
		<% } %>

		<%- body %>

		<% if (typeof stage === 'undefined' || stage !== '2') { %>
		<footer class="liquid-glass">
			<div id="haiku-display">
				<span id="haiku-line-1"></span>
				<span id="haiku-line-2"></span>
				<span id="haiku-line-3"></span>
			</div>
		</footer>
		<% } %>

		<!-- Guide / main popup — shared across all pages -->
		<section
			id="main-popup"
			class="liquid-glass hidden"
			style="
				position: fixed;
				left: 50%;
				top: 50%;
				transform: translate(-50%, -50%);
				z-index: 10001;
				min-width: 320px;
				max-width: 560px;
				width: 90%;
				padding: 2rem;
			">
			<p id="main-popup-text" style="line-height: 1.7; text-align: center;"></p>
			<div id="main-popup-status" style="text-align: left; margin-top: 0.5rem; max-height: 200px; overflow: auto"></div>
			<div id="main-popup-buttons" style="display: flex; gap: 0.75rem; justify-content: center; margin-top: 1.5rem">
				<button id="main-popup-back" class="liquid-glass button-link" type="button">
					<span class="carved-glass">Back</span>
				</button>
				<button id="main-popup-continue" class="liquid-glass button-link" type="button">
					<span class="carved-glass">Continue</span>
				</button>
				<button id="main-popup-submit" class="liquid-glass button-link" type="button">
					<span class="carved-glass">Submit</span>
				</button>
				<button id="main-popup-ok" class="liquid-glass button-link hidden" type="button">
					<span class="carved-glass">OK</span>
				</button>
			</div>
		</section>

		<script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
		<script src="/FxFilter.js" onerror="console.log('FxFilter.js not found - skipping FX effects')"></script>
		<script type="module" src="/main.js"></script>
	</body>
</html>
