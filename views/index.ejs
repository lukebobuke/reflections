<!-- @format -->

<main class="liquid-glass">
	<section>
		<h2>Recent Sculptures</h2>
		<% if (!user) { %>
		<p style="text-align: center; margin-bottom: var(--padding); color: rgba(var(--text-color), 0.8);">
			Sculptures forged by our community.
		</p>
		<% } %>
	</section>
</main>
<div id="sculpture-feed"></div>

<script>
	window.__HOME_PAGE_STATE__ = {
		isLoggedIn: <%= user ? 'true' : 'false' %>,
		showWelcome: <%= typeof showWelcome !== 'undefined' ? showWelcome : false %>
	};
</script>
<script type="module" src="/index.js"></script>
